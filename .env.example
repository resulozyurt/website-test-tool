# --- Target site -----------------------------------------------------------
# Production base URL. Phase 0 verifies the live geo/cache behavior here.
TARGET_BASE_URL=https://www.fieldpie.com

# --- Country-targeted proxies ----------------------------------------------
# One residential proxy endpoint per target country, with a STICKY session so
# the same country IP is kept for the whole visit (required for stable cache
# bucketing). Most pay-as-you-go residential providers encode the country and
# the sticky session inside the username.
#
# Expected format (full URL, including credentials):
#   http://USERNAME:PASSWORD@HOST:PORT
#
# Example shape for a residential provider (the exact username syntax depends
# on the provider you sign up for; we confirm it during Phase 0):
#   PROXY_US=http://user-cc-us-sessid-poc1:pass@proxy.provider.net:12321
#
PROXY_US=
PROXY_AE=
PROXY_TR=

# --- Runtime tuning (optional) ---------------------------------------------
# Milliseconds to wait for network to settle before capturing the page.
SETTLE_MS=4000
# Navigation timeout in milliseconds.
NAV_TIMEOUT_MS=45000
